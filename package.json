{
  "name": "midnight-dust-sponsorship-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Example: one wallet (sponsor) pays DUST transaction fees for another wallet (user) on Midnight.",
  "license": "Apache-2.0",
  "author": "Olanetsoft",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:contract": "compact compile contracts/authorized-action.compact src/managed/authorized-action",
    "deploy": "tsx src/deploy.ts",
    "fund": "tsx src/fund-wallets.ts",
    "sponsor": "tsx src/sponsor-service.ts",
    "user": "tsx src/user-client.ts",
    "verify": "tsx src/verify.ts",
    "e2e": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-protocol": "4.1.1",
    "@midnight-ntwrk/midnight-js-types": "4.1.1",
    "@midnight-ntwrk/midnight-js-utils": "4.1.1",
    "@midnight-ntwrk/testkit-js": "4.1.1",
    "@midnight-ntwrk/wallet-sdk": "1.1.0",
    "express": "^4.21.2",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "@midnight-ntwrk/ledger-v8": "8.1.0",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1"
  }
}
